msgid "TC backend"
msgstr "TC bagian belakang"

msgid "Select TC attach backend. Recommendation: use auto by default; tcx is preferred on kernel >= 6.6; netlink is safer on older kernels."
msgstr "memilih TC Pasang bagian belakang。Disarankan untuk menggunakan default auto；di kernel >= 6.6 prioritas saat menggunakan tcx；Penggunaan kernel lama netlink lebih aman。"

msgid "TC order"
msgstr "TC memesan"

msgid "Netlink priority"
msgstr "Netlink prioritas"

msgid "Only used when backend is netlink. Range: 0..65535 (0 means default)."
msgstr "Hanya di backend saja netlink digunakan kapan。cakupan：0..65535（0 Menunjukkan bawaan）。"

msgid "TCX ingress anchor program id"
msgstr "TCX program jangkar masuk ID"

msgid "Used when tc_order is before/after. Must be a valid ingress program id on the same interface."
msgstr "Kapan tc_order untuk before/after digunakan kapan。Harus berupa program masuk yang valid pada antarmuka yang sama ID。"

msgid "TCX egress anchor program id"
msgstr "TCX program jangkar keluar ID"

msgid "Used when tc_order is before/after. Must be a valid egress program id on the same interface."
msgstr "Kapan tc_order untuk before/after digunakan kapan。Harus berupa program keluar yang valid pada antarmuka yang sama ID。"
